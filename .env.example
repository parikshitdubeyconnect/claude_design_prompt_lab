# ── Prompt Lab environment ──
# Copy to `.env.local` and fill in. All keys are server-side only.

# Anthropic API key (required for live Claude calls). Without it the app runs
# in a graceful "demo mode" that streams a placeholder instead.
ANTHROPIC_API_KEY=

# Realtime session store. When these are set, session state is kept in Upstash
# Redis (recommended on Vercel). When absent, the app falls back to an in-memory
# store — fine for local dev / a single serverless instance, not for scale-out.
# Vercel KV also works: it injects KV_REST_API_URL / KV_REST_API_TOKEN.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Public base URL, used to build the join URL encoded in the QR when it can't be
# derived from the request (e.g. server-side rendering). Optional.
NEXT_PUBLIC_BASE_URL=
